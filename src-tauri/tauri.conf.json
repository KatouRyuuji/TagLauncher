{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TagLauncher",
  "version": "1.0.0",
  "identifier": "com.taglauncher.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3456",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TagLauncher",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": null
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:taglauncher.db"]
    },
    "shell": {
      "open": true
    }
  }
}
